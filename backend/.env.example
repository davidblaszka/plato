# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Database — matches docker-compose.yml defaults
DATABASE_URL=postgresql+asyncpg://plato:plato@db:5432/plato

# JWT — generate a strong random string for production
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-use-a-long-random-string-in-production

# Cloudflare R2 (S3-compatible object storage for media uploads)
# Create a bucket at dash.cloudflare.com → R2 → Create bucket
# Then create an API token with Object Read & Write permissions
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=plato-media
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
